     "sas_provenance": {"source_file": "02_clean.sas", "sas_construct": "DATA_STEP"}},

    {"id": "step_merge", "node_type": "DataStep",
     "input_datasets": ["work.survey_clean", "refdata.geo_lookup"], "output_dataset": "work.survey_merged",
