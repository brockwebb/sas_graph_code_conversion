     "sas_provenance": {"source_file": "03_merge.sas", "sas_construct": "DATA_STEP"}},

    {"id": "step_impute", "node_type": "DataStep",
     "input_datasets": ["work.survey_merged"], "output_dataset": "work.survey_imputed",
     "where_clause": null,
     "sas_provenance": {"source_file": "04_impute.sas", "sas_construct": "DATA_STEP",
