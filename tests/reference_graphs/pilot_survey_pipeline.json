    {"id": "xfm_ingest_survey", "node_type": "Transform",
     "operation": "set", "description": "Read raw survey file into WORK library",
     "parameters": {"input_file": "rawdata.survey", "output_dataset": "work.survey_clean"},
     "sas_provenance": {"source_file": "01_ingest.sas", "sas_construct": "DATA_STEP"}},

    {"id": "xfm_ingest_geo", "node_type": "Transform",
     "operation": "set", "description": "Read geographic lookup table into WORK library",
     "parameters": {"input_file": "refdata.geo_lookup"},
     "sas_provenance": {"source_file": "01_ingest.sas", "sas_construct": "DATA_STEP"}},

    {"id": "xfm_clean_income_range", "node_type": "Transform",
     "operation": "conditional_assign",
     "description": "Recode out-of-range income values to SAS missing (.)",
     "parameters": {"condition": "income < 0 OR income > 9999999", "then": "income_clean = .", "else": "income_clean = income"},
     "sas_provenance": {"source_file": "02_clean.sas", "sas_construct": "DATA_STEP"}},

    {"id": "xfm_recode_race_array", "node_type": "Transform",
     "operation": "array_op",
     "description": "Array-based validation and recoding of race code",
     "parameters": {"array": "race_codes", "do_loop": "i = 1 to 6"},
     "sas_provenance": {"source_file": "02_clean.sas", "sas_construct": "DATA_STEP"}},

    {"id": "xfm_derive_age_group", "node_type": "Transform",
     "operation": "conditional_assign",
     "description": "Recode continuous age into categorical age group (1=<18, 2=18-34, 3=35-54, 4=55-64, 5=65-74, 6=75+)",
     "parameters": {"breakpoints": [18, 35, 55, 65, 75]},
     "sas_provenance": {"source_file": "02_clean.sas", "sas_construct": "DATA_STEP"}},

    {"id": "xfm_sort_pre_merge", "node_type": "Transform",
     "operation": "sort",
     "description": "Sort survey data by fips_code before geographic merge",
     "parameters": {"by": ["fips_code"]},
     "sas_provenance": {"source_file": "03_merge.sas", "sas_construct": "PROC_SORT"}},

    {"id": "xfm_merge_geo", "node_type": "Transform",
     "operation": "merge",
     "description": "Match-merge survey data with geography lookup on FIPS code",
     "parameters": {"by": ["fips_code"], "merge_type": "many_to_one"},
     "sas_provenance": {"source_file": "03_merge.sas", "sas_construct": "DATA_STEP"}},

    {"id": "xfm_sort_pre_impute", "node_type": "Transform",
     "operation": "sort",
     "description": "Sort merged data by fips_code, age for hot-deck imputation",
     "parameters": {"by": ["fips_code", "age"]},
     "sas_provenance": {"source_file": "04_impute.sas", "sas_construct": "PROC_SORT"}},

    {"id": "xfm_hotdeck_income", "node_type": "Transform",
     "operation": "retain",
     "description": "Hot-deck imputation of missing income within FIPS strata using RETAIN + FIRST./LAST. by-group",
     "parameters": {"strata_variable": "fips_code", "sort_variable": "age",
                    "donor_requirement": "non_missing_income", "target_variable": "income_imputed"},
     "sas_provenance": {"source_file": "04_impute.sas", "sas_construct": "DATA_STEP",
                        "uses_retain": true, "uses_by_group": true}},

    {"id": "xfm_derive_poverty_ratio", "node_type": "Transform",
     "operation": "assign",
     "description": "Compute poverty ratio: income_imputed / poverty_threshold",
     "parameters": {"formula": "poverty_ratio = income_imputed / poverty_threshold"},
     "sas_provenance": {"source_file": "05_derive.sas", "sas_construct": "DATA_STEP"}},

    {"id": "xfm_derive_in_poverty", "node_type": "Transform",
     "operation": "conditional_assign",
     "description": "Binary indicator: in_poverty = 1 if poverty_ratio < 1, else 0",
     "parameters": {"condition": "poverty_ratio < 1", "then": "in_poverty = 1", "else": "in_poverty = 0"},
     "sas_provenance": {"source_file": "05_derive.sas", "sas_construct": "DATA_STEP"}},

    {"id": "xfm_derive_weighted_income", "node_type": "Transform",
     "operation": "assign",
     "description": "Compute weighted income: income_imputed * survey_weight",
     "parameters": {"formula": "weighted_income = income_imputed * survey_weight"},
     "sas_provenance": {"source_file": "05_derive.sas", "sas_construct": "DATA_STEP"}},

    {"id": "xfm_sort_pre_agg", "node_type": "Transform",
     "operation": "sort",
     "description": "Sort derived data by region, age_group for aggregation",
     "parameters": {"by": ["region", "age_group"]},
     "sas_provenance": {"source_file": "06_aggregate.sas", "sas_construct": "PROC_SORT"}},

    {"id": "xfm_aggregate_surveymeans", "node_type": "Transform",
     "operation": "survey_stat",
     "description": "PROC SURVEYMEANS — compute weighted mean income and SE by region and age_group using replicate weights",
     "parameters": {
       "proc": "SURVEYMEANS",
       "weight": "survey_weight",
       "repweights": ["rep_weight_1","rep_weight_2","rep_weight_3","rep_weight_4","rep_weight_5",
                      "rep_weight_6","rep_weight_7","rep_weight_8","rep_weight_9","rep_weight_10"],
       "varmethod": "JK",
       "var": ["income_imputed", "in_poverty"],
       "domain": ["region", "age_group"]
     },
     "sas_provenance": {"source_file": "06_aggregate.sas", "sas_construct": "PROC_SURVEYMEANS"}},

    {"id": "xfm_aggregate_freq", "node_type": "Transform",
     "operation": "frequency",
     "description": "PROC FREQ — compute unweighted respondent counts by region and age_group",
     "parameters": {"proc": "PROC_FREQ", "tables": "region * age_group"},
     "sas_provenance": {"source_file": "06_aggregate.sas", "sas_construct": "PROC_FREQ"}},

