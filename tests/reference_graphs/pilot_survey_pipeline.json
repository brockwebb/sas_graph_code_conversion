     "sas_provenance": {"source_file": "01_ingest.sas", "sas_construct": "DATA_STEP"}},

    {"id": "step_clean", "node_type": "DataStep",
     "input_datasets": ["work.survey_raw"], "output_dataset": "work.survey_clean",
